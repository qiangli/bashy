# DHNT CI auto-repair dispatcher config.
#
# Source of truth for the GitHub token is cloudbox secret:
#   dhnt-ci-failures-token
#
# The dispatcher expects each source repo to have Actions secret
# CI_FAILURE_TOKEN synced from that cloudbox secret.
# Source repo workflows emit repository_dispatch event ci-failure-filed to the
# collector repo after filing/updating a CI-failure issue. The collector-side
# repair workflow runs on a self-hosted runner labeled dhnt-repair and calls:
#   scripts/ci-failure-router.sh --once --issue "$COLLECTOR_ISSUE"
# If the workflow lives in the collector repo rather than this checkout, set
# repository variable DHNT_CI_REPAIR_ROUTER to the absolute router path on that
# runner.

DHNT_CI_COLLECTOR_REPO=qiangli/dhnt-ci-failures
DHNT_CI_REPAIR_DISPATCH_EVENT=ci-failure-filed
DHNT_CI_REPAIR_RUNNER_LABEL=dhnt-repair
DHNT_CI_ROOT=/Users/qiangli/projects/poc/dhnt

# Shift selection is evaluated on the host running the scheduler. The default
# is one-hour shifts alternating codex/claude; set DHNT_CI_SHIFT_HOURS=2,3,8...
# to use longer shifts.
DHNT_CI_SHIFT_HOURS=1
DHNT_CI_SHIFT_ROSTER=codex,claude

# Compatibility knobs for the current prototype. The router refactor should use
# DHNT_CI_SHIFT_ROSTER instead of even/odd-specific fixer keys.
DHNT_CI_EVEN_FIXER=codex
DHNT_CI_ODD_FIXER=claude

# Workers exclude the active fixer, so retries get tool diversity.
DHNT_CI_EVEN_WORKERS=claude,agy,opencode,aider
DHNT_CI_ODD_WORKERS=codex,agy,opencode,aider

DHNT_CI_REPOS=qiangli/bashy=bashy,qiangli/coreutils=coreutils,qiangli/sh=sh,qiangli/readline=readline,qiangli/outpost=outpost,qiangli/ycode=ycode

# Band escalation (supersedes shift-parity fixer selection). Each repair
# attempt runs at a capability band resolved through `bashy agents --band`; a RED
# supervisor gate or the per-attempt timebox escalates to the next band. Past the
# ladder → notify a human (Decision B: L4/fable5 is NOT spent unattended).
#   attempt 1 → band 2 (cheapest sufficient), attempt 2 → band 3 (diagnosis).
DHNT_CI_BAND_LADDER=2,3
DHNT_CI_BAND_TIMEBOX=30m
DHNT_CI_ESCALATE_ON=timeout,red-gate

# Fixer selection (fixers are NEVER dedicated — chosen dynamically from `bashy
# agents` at the attempt's band). Cost lane: SUBSCRIPTION first (flat cost),
# metered API keys only when urgent. The pick rotates ROUND-ROBIN across the pool
# to spread rate-limited subscription quota (not random — random can hit one
# account twice running).
#   DHNT_CI_FIXER_ALLOW_METERED=1 → allow metered API-key agents (urgent); default
#     0 = subscription-only, falling back to metered only if no subscription agent
#     resolves at the band.
DHNT_CI_FIXER_ALLOW_METERED=0
#   Optional pool constraints (empty = the whole band). Narrow by tool and/or by
#   agent name, e.g. DHNT_CI_FIXER_TOOLS=codex,claude or DHNT_CI_FIXER_AGENTS=codex-gpt-5.5.
DHNT_CI_FIXER_TOOLS=
DHNT_CI_FIXER_AGENTS=

# Fleet concurrency: how many repos to repair in PARALLEL (one fixer each). When a
# shared change breaks the whole fleet, set this to the fleet size (e.g. 5) so the
# wall-clock stays one timebox instead of N × timebox. Default 1 = sequential.
DHNT_CI_CONCURRENCY=1
# P4 human escalation: a GitHub repo used as the human queue. When the band
# ladder is exhausted, file/append an issue here — GitHub's watch feature
# notifies watchers for free (email/mobile) and the issue is TUI-workable (gh).
# Empty → comment the collector issue only. No SMTP/Gmail. A private repo keeps
# escalations off the public collector; the same pipeline can later auto-fix it.
DHNT_CI_ESCALATION_REPO=qiangli/dhnt-ci-escalations
# Optional explicit gate command per repair (else `bashy gate --json` auto-detects
# the repo's gate). Runs on the SUPERVISOR, never trusts the worker's exit code.
DHNT_CI_GATE_CMD=

DHNT_CI_MAX_ATTEMPTS=2
DHNT_CI_TURN_TIMEOUT=45m
DHNT_CI_GATE_TIMEOUT=25m
DHNT_CI_SANDBOX=danger-full-access
DHNT_CI_LIMIT=1

# ── P3 notify: hybrid push + pull ──────────────────────────────────────────
# The repair host runs the band-escalating router two ways; both are idempotent
# (repair-running label + the outpost /admin/repair concurrency cap dedup them).
#
# PUSH (instant): cloudbox's CI-failure webhook fans out POST /admin/repair over
# the matrix tunnel. Enable the receiver on this host by pointing it at the
# router (outpost reads OUTPOST_REPAIR_CMD; argv, space-split):
#   OUTPOST_REPAIR_CMD="bash /path/to/bashy/scripts/ci-failure-router.sh --once"
# and tell cloudbox which host(s) to push to: CI_REPAIR_HOSTS=<this-host-name>.
#
# PULL (reliable backstop): register a recurring poll with bashy's cron (the
# outpost already supervises `bashy schedule daemon`) — run ONCE on the host:
#   bashy schedule add --id ci-repair-poll --every 3m -- \
#     bash /path/to/bashy/scripts/ci-failure-router.sh --once
# The router polls the collector issues; a missed/offline push is picked up on
# the next tick, so the pipeline never stalls on a push that didn't land.

# Planned router/fixer mode. The scheduler is cheap deterministic routing;
# the band-selected fixer is launched only when a claimable failure exists.
DHNT_CI_REPAIR_MODE=weave
DHNT_CI_REQUIRE_HANDOFF=1
DHNT_CI_REQUIRE_RECOVERY_GATE=1
DHNT_CI_HANDOFF_DIR=/Users/qiangli/.bashy/ci-repair
