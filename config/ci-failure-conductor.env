# DHNT CI auto-repair dispatcher config.
#
# Source of truth for the GitHub token is cloudbox secret:
#   dhnt-ci-failures-token
#
# The dispatcher expects each source repo to have Actions secret
# CI_FAILURE_TOKEN synced from that cloudbox secret.
# Source repo workflows emit repository_dispatch event ci-failure-filed to the
# collector repo after filing/updating a CI-failure issue. The collector-side
# repair workflow runs on a self-hosted runner labeled dhnt-repair and calls:
#   scripts/ci-failure-router.sh --once --issue "$COLLECTOR_ISSUE"
# If the workflow lives in the collector repo rather than this checkout, set
# repository variable DHNT_CI_REPAIR_ROUTER to the absolute router path on that
# runner.

DHNT_CI_COLLECTOR_REPO=qiangli/dhnt-ci-failures
DHNT_CI_REPAIR_DISPATCH_EVENT=ci-failure-filed
DHNT_CI_REPAIR_RUNNER_LABEL=dhnt-repair
DHNT_CI_ROOT=/Users/qiangli/projects/poc/dhnt

# Shift selection is evaluated on the host running the scheduler. The default
# is one-hour shifts alternating codex/claude; set DHNT_CI_SHIFT_HOURS=2,3,8...
# to use longer shifts.
DHNT_CI_SHIFT_HOURS=1
DHNT_CI_SHIFT_ROSTER=codex,claude

# Compatibility knobs for the current prototype. The router refactor should use
# DHNT_CI_SHIFT_ROSTER instead of even/odd-specific conductor keys.
DHNT_CI_EVEN_CONDUCTOR=codex
DHNT_CI_ODD_CONDUCTOR=claude

# Workers exclude the active conductor, so retries get tool diversity.
DHNT_CI_EVEN_WORKERS=claude,agy,opencode,aider
DHNT_CI_ODD_WORKERS=codex,agy,opencode,aider

DHNT_CI_REPOS=qiangli/bashy=bashy,qiangli/coreutils=coreutils,qiangli/sh=sh,qiangli/readline=readline,qiangli/outpost=outpost,qiangli/ycode=ycode

# Band escalation (supersedes shift-parity conductor selection). Each repair
# attempt runs at a capability band resolved through `bashy agents --band`; a RED
# supervisor gate or the per-attempt timebox escalates to the next band. Past the
# ladder → notify a human (Decision B: L4/fable5 is NOT spent unattended).
#   attempt 1 → band 2 (cheapest sufficient), attempt 2 → band 3 (diagnosis).
DHNT_CI_BAND_LADDER=2,3
DHNT_CI_BAND_TIMEBOX=30m
DHNT_CI_ESCALATE_ON=timeout,red-gate
# How to notify when the ladder is exhausted: email (cloudbox SendMail) | comment.
DHNT_CI_HUMAN_NOTIFY=comment
# Optional explicit gate command per repair (else `bashy gate --json` auto-detects
# the repo's gate). Runs on the SUPERVISOR, never trusts the worker's exit code.
DHNT_CI_GATE_CMD=

DHNT_CI_MAX_ATTEMPTS=2
DHNT_CI_TURN_TIMEOUT=45m
DHNT_CI_GATE_TIMEOUT=25m
DHNT_CI_SANDBOX=danger-full-access
DHNT_CI_LIMIT=1

# Planned router/conductor mode. The scheduler is cheap deterministic routing;
# the on-shift premium model is launched only when a claimable failure exists.
DHNT_CI_REPAIR_MODE=weave
DHNT_CI_REQUIRE_HANDOFF=1
DHNT_CI_REQUIRE_RECOVERY_GATE=1
DHNT_CI_HANDOFF_DIR=/Users/qiangli/.bashy/ci-repair
