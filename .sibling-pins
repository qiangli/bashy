# Pinned commit SHAs for the sibling-path replace targets in go.mod
# (../sh, ../coreutils). scripts/bootstrap-siblings.sh reads this file and
# clones each sibling at the listed SHA, so standalone clones of bashy (and
# CI) build without external setup. coreutils itself replaces ../sh, which
# resolves to the same flat sibling.
#
# Inside the dhnt umbrella the siblings already exist as submodules
# (dhnt/sh, dhnt/coreutils) — the bootstrap script detects them and leaves
# them alone, so there is still exactly one copy of each.
#
# Format: <name>=<sha>. When bumping a sibling in the umbrella's
# script/sync.sh, the SHA here is bumped to match — sync.sh automates this.
sh=5dc617763f4af51616185acbf826775dd1d5eb53
coreutils=433a5c28e19148165b0b3ea300beb674851ed0f0
readline=d29dca5d747044b347dd31b7eb32cb9835af96d6
