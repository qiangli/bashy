# Pinned commit SHA for the sibling-path replace target in go.mod (../sh).
# scripts/bootstrap-siblings.sh reads this file and clones the sibling at the
# listed SHA, so standalone clones of bashy (and CI) build without external
# setup.
#
# Inside the dhnt umbrella the sibling already exists as a submodule
# (dhnt/sh) — the bootstrap script detects it and leaves it alone, so there
# is still exactly one copy.
#
# Format: <name>=<sha>. When bumping sh in the umbrella's script/sync.sh, the
# SHA here is bumped to match — sync.sh automates this.
sh=daa95d5bfff72cdc2e9ff91948ebb36b386cf6ed
