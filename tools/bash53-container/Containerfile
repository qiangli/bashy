# Bash 5.3 conformance container substrate.
#
# The stock docker.io/library/gcc:14-bookworm image ships only C / C.UTF-8, so
# the locale-sensitive fixtures (`intl` needs de_DE.UTF-8, `glob-test` needs
# zh_TW.big5) fail in-container while they pass natively on a dev box that has
# the locales. Bake the locale set the bash-5.3 suite exercises so the
# container lane reproduces the native gate. Everything here is a build-time
# (root) step; the lane runs the container non-root via `--userns=keep-id`.
FROM docker.io/library/gcc:14-bookworm

# `locales` covers the locale-sensitive fixtures; `bsdextrautils` supplies
# `hexdump`, which `printf6.sub` shells out to and the stock gcc image lacks.
RUN set -eux; \
    apt-get update; \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      locales bsdextrautils; \
    rm -rf /var/lib/apt/lists/*; \
    printf '%s\n' \
      'C.UTF-8 UTF-8' \
      'en_US.UTF-8 UTF-8' \
      'en_US ISO-8859-1' \
      'de_DE.UTF-8 UTF-8' \
      'de_DE ISO-8859-1' \
      'fr_FR.UTF-8 UTF-8' \
      'fr_FR ISO-8859-1' \
      'ja_JP.UTF-8 UTF-8' \
      'ja_JP EUC-JP' \
      'ja_JP.SJIS SHIFT_JIS' \
      'zh_TW BIG5' \
      > /etc/locale.gen; \
    locale-gen
