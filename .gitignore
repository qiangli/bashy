bin/
/bash

# Bash 5.3 compliance fixtures are a local, gitignored symlink into a bash
# source tree (only its tests/ dir is used). Each developer points this at
# their own checkout; `make test-bash` reads through it. See README / CLAUDE.md.
external/bash-5.3

# Agent / editor session artifacts
.claude/
.aider*
.agents/
.gfy-out/

# Runtime/eval output can contain local paths, command transcripts, provider
# metadata, or secrets from failures. Keep raw runs local; commit sanitized
# summaries under docs/ or another reviewed location instead.
results/*
!results/README.md

# Prior-art reference clones for studying/adapting POSIX shell behavior.
# Local only, never committed (we adapt algorithms into Go with attribution,
# we do not redistribute upstream sources). Policy: docs/priorart-policy.md
/priorart/

# yash GPL test-suite clone cache (never vendored)
.yash-tests/

# zsh test-suite clone cache (never vendored; scored via scripts/zsh-scoreboard.sh)
.zsh-tests/
bin/.bashy-linux-*

# dash upstream clone cache (never vendored; dash ships no test suite — used as oracle)
.dash-tests/

# modernish (MIT) feature/regression suite clone cache (never vendored)
.modernish-tests/

# Licensed VSC-PCTS2016 suite (The Open Group) — NOT redistributable: the license
# forbids copying/distributing the Test Suites, and forbids publishing results or
# a "passed" claim without their prior written consent. The harness stages it in
# $HOME/.cache/vsc-pcts (outside the repo); these rules just make an accidental
# in-tree copy uncommittable. Ditto the signed license agreement (personal data).
VSC-PCTS*
vsc-pcts*/
*VSC-PCTS*.pdf
tet3/
vsxgen/
